  "hints": [
    {
      "id": "h1",
      "subtaskId": "st1",
      "content": "Fast power: if (b & 1) res = res * a; a = a * a; b >>= 1.",
      "starCost": 0
    },
    {
      "id": "h2",
      "subtaskId": "st2",
      "content": "Khai báo `unsigned long long` cho m·m có thể tới 10^{18} (gần overflow).",
      "starCost": 1
    },
    {
      "id": "h3",
      "subtaskId": "st3",
      "content": "Hoặc dùng `__int128`.",
      "starCost": 1
    }
  ],
  "editorial": "Fast power lặp hoặc đệ quy. O(log b).",
  "solutionSketch": "long long pw(long long a, long long b, long long m) { long long r = 1; a %= m; while (b) { if (b & 1) r = (__int128)r * a % m; a = (__int128)a * a % m; b >>= 1; } return r; }",
