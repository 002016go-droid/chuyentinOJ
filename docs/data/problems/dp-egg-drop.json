  "hints": [
    {
      "id": "dp-egg-drop-h1",
      "subtaskId": "st1",
      "content": "K=1: phải thử tuần tự, đáp án N. K=2 dùng DP nhỏ.",
      "starCost": 0
    },
    {
      "id": "dp-egg-drop-h2",
      "subtaskId": "st2",
      "content": "dp[i][j] = min worst-case với i trứng, j tầng. Thử thả tại tầng x.",
      "starCost": 1
    },
    {
      "id": "dp-egg-drop-h3",
      "subtaskId": "st3",
      "content": "Công thức: dp[i][j] = min(1 + max(dp[i-1][x-1], dp[i][j-x])) với x=1..j. O(K·N²).",
      "starCost": 1
    }
  ],
  "editorial": "dp[i][j] = số lần thả tối thiểu trong worst-case với i trứng, j tầng. Base: dp[1][j]=j; dp[i][0]=0. Trans: dp[i][j] = min trên x=1..j của 1 + max(dp[i-1][x-1] (vỡ → còn i-1 trứng, x-1 tầng dưới), dp[i][j-x] (nguyên → còn i trứng, j-x tầng trên)). O(K·N²) đủ AC trong giới hạn này.",
  "solutionSketch": "// dp[i][j] = min over x: 1 + max(dp[i-1][x-1], dp[i][j-x])",
