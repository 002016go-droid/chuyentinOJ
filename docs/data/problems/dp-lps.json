    {
      "id": "dp-lps-h3",
      "subtaskId": "st3",
      "content": "DP interval: dp[i][j] = LPS trong S[i..j]. Trans dùng s[i]?=s[j].",
      "starCost": 1
    }
  ],
  "editorial": "dp[i][j] = LPS độ dài trong S[i..j]. Base: dp[i][i]=1. Trans: nếu S[i]=S[j] thì dp[i][j] = dp[i+1][j-1] + 2 (với L=2 → 2). Ngược lại dp[i][j] = max(dp[i+1][j], dp[i][j-1]). Lặp theo L=2..n. O(n²).",
  "solutionSketch": "// dp[i][i]=1; for L=2..n: dp[i][j]=s[i]==s[j]?dp[i+1][j-1]+2:max(dp[i+1][j],dp[i][j-1])",
