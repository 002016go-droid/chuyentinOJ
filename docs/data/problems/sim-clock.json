  "hints": [
    {
      "id": "h1",
      "content": "Chuyển HH:MM:SS sang tổng giây = H·3600 + M·60 + S. Cộng dt. Mod 86400.",
      "starCost": 0,
      "subtaskId": "st1"
    },
    {
      "id": "h2",
      "content": "Đọc HH:MM:SS dùng `scanf(\"%d:%d:%d\", &h, &m, &s)`.",
      "starCost": 1,
      "subtaskId": "st2"
    },
    {
      "id": "h3",
      "content": "Khai báo long long cho S khi tới 10^18. In với `setfill('0') << setw(2)`.",
      "starCost": 1,
      "subtaskId": "st3"
    }
  ],
  "editorial": "Tổng giây sau cộng và mod 86400. Tách lại HH:MM:SS bằng phép chia.",
  "solutionSketch": "long long total = (h * 3600 + m * 60 + s + S) % 86400; printf(\"%02d:%02d:%02d\", total/3600, total%3600/60, total%60);",
